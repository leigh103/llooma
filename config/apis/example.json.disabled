{
  "name": "my-service",
  "description": "What this API does and when to use it — the model reads this to decide when to call it",
  "baseUrl": "https://api.example.com",
  "cacheTtlSeconds": 300,
  "auth": null
}

// With auth (token stored in .env, not the config file):
// {
//   "name": "my-service",
//   "description": "...",
//   "baseUrl": "https://api.example.com",
//   "auth": {
//     "header": "x-api-key",
//     "value": "env:MY_SERVICE_API_KEY"
//   }
// }
//
// Add the actual token to .env:
// MY_SERVICE_API_KEY=your-token-here

// With API training (fetches endpoint, writes markdown to docs/, ingests):
// {
//   "name": "my-service",
//   "description": "...",
//   "baseUrl": "https://api.example.com",
//   "train": {
//     "endpoint": "/articles",
//     "excludeFields": ["created_at", "image_url"]
//   },
//   "auth": null
// }

// With local file reading (LLM summarises each file and saves as markdown):
// {
//   "name": "my-codebase",
//   "read": {
//     "files": [
//       "/path/to/src/routes/users.js",
//       "/path/to/src/models/invoice.js"
//     ],
//     "prompt": "Summarise what this file does, its key functions, and how it fits into the application. Be concise."
//   }
// }
//
// "prompt" is optional — a sensible default is used if omitted.

// With web scraping — explicit URLs (recommended for Cloudflare-protected sites):
// {
//   "name": "my-site",
//   "scrape": {
//     "urls": [
//       "https://example.com/page-one",
//       "https://example.com/page-two"
//     ],
//     "delayMs": 500
//   }
// }

// With web scraping — crawl from root (follows links automatically):
// {
//   "name": "my-site",
//   "scrape": {
//     "url": "https://example.com",
//     "depth": 2,
//     "maxPages": 50,
//     "delayMs": 1000
//   }
// }
//
// Note: crawl mode may fail on sites with Cloudflare or similar bot protection.
// Use the explicit urls array instead.
