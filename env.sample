# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma4:e4b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.7
OLLAMA_NUM_PREDICT=2048
OLLAMA_KEEP_ALIVE=-1

# SQLite vector store
DB_PATH=./data/knowledge.db
#RAG_TOP_K=3           # number of chunks injected into prompt (3=faster/shorter, 5=slower/fuller)
#RAG_MAX_PER_SOURCE=2  # max chunks from the same source in top-k (prevents one file dominating)
#RAG_MIN_SCORE=0       # minimum RRF score to include a chunk (0=disabled, try 0.01 to filter weak matches)

# Default location for weather queries (e.g. "London, UK" or "51.5074,-0.1278")
#DEFAULT_LOCATION=London, UK

# Memory extraction (set to false to disable persistent memory — good for customer-facing agents)
#MEMORY_ENABLED=false

# Agent identity
AGENT_NAME=Llooma
AGENT_DESCRIPTION=Personal Ollama agent
#AGENT_SYSTEM_PROMPT=You are Llooma, a personal AI assistant powered by Ollama.

# Server
PORT=3000
#API_KEY=change-me-to-something-secret

# Docs folder to ingest
DOCS_PATH=./docs

# API services folder
#API_SERVICES_PATH=./config/apis

# Slack (optional)
#SLACK_BOT_TOKEN=xoxb-your-token
#SLACK_SIGNING_SECRET=your-signing-secret
#SLACK_APP_TOKEN=xapp-your-app-token

# Web search (optional - get free key at https://api.search.brave.com)
#BRAVE_API_KEY=
