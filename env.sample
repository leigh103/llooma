# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma4:e4b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.7
OLLAMA_NUM_PREDICT=2048
OLLAMA_KEEP_ALIVE=-1

# SQLite vector store
DB_PATH=./data/knowledge.db

# Memory extraction (set to false to disable persistent memory — good for customer-facing agents)
#MEMORY_ENABLED=false

# Agent identity
AGENT_NAME=Lloom
AGENT_DESCRIPTION=Personal Ollama agent
#AGENT_SYSTEM_PROMPT=You are Lloom, a personal AI assistant powered by Ollama.

# Server
PORT=3000
#API_KEY=change-me-to-something-secret

# Docs folder to ingest
DOCS_PATH=./docs

# API services folder
#API_SERVICES_PATH=./config/apis

# Slack (optional)
#SLACK_BOT_TOKEN=xoxb-your-token
#SLACK_SIGNING_SECRET=your-signing-secret
#SLACK_APP_TOKEN=xapp-your-app-token

# Web search (optional - get free key at https://api.search.brave.com)
#BRAVE_API_KEY=
